# =============================================================================
# ai-data-registry - Local Development Environment
# =============================================================================
# Copy to .env and fill in values. Never commit .env to git.
#
#   cp .env.example .env
#
# The setup script (setup.sh / setup.ps1) can generate this for you.
# Claude Code cannot read .env files (blocked by settings.json for security).
# =============================================================================

# --- Default Storage: eu-hetzner (Required for catalog operations) -----------
# Secret names match [storage.eu-hetzner] in .github/registry.config.toml.
# For multi-storage, add additional sets with the secret names from each
# [storage.<name>] section (e.g. S3_US_ENDPOINT_URL for [storage.us-east]).
S3_ENDPOINT_URL=
S3_BUCKET=
S3_REGION=
S3_WRITE_KEY_ID=
S3_WRITE_SECRET=

# --- Hetzner Backend (Optional) ---------------------------------------------
# Only needed if you use backend = "hetzner" in workspace configs
HCLOUD_TOKEN=

# --- HuggingFace Backend (Optional) -----------------------------------------
# Only needed if you use backend = "huggingface" in workspace configs
HF_TOKEN=

# --- Per-Workspace Secrets (Optional) ---------------------------------------
# Pattern: WS_{WORKSPACE_NAME}_API_KEY
# These become $WORKSPACE_SECRET_API_KEY inside workspace extract scripts.
# Uncomment and add as needed:
# WS_weather_API_KEY=
# WS_openmeteo_API_KEY=
